<Window x:Class="CryoChaos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CryoChaos.Models"
        Title="CryoChaos"
        Width="1080"
        Height="760"
        MinWidth="900"
        MinHeight="650"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="CryoChaos" FontSize="28" FontWeight="Bold" />
            <TextBlock Text="External Destiny 2 chaos controller — graphic and keybind effects"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource CardBrush}"
                CornerRadius="10"
                Padding="14"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="155" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Mode" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox x:Name="ModeComboBox"
                          Grid.Column="1" />

                <TextBlock Grid.Column="3" Text="Minimum interval" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="MinimumIntervalTextBox" Grid.Column="4" Text="35" />

                <TextBlock Grid.Column="6" Text="Maximum interval" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="MaximumIntervalTextBox" Grid.Column="7" Text="70" />

                <CheckBox x:Name="RequireForegroundCheckBox"
                          Grid.Column="9"
                          Content="Only send keybinds while Destiny 2 is focused"
                          IsChecked="True"
                          VerticalAlignment="Center" />
            </Grid>
        </Border>

        <TabControl Grid.Row="2" Background="Transparent" BorderBrush="#343A49">
            <TabItem Header="Effects">
                <DataGrid x:Name="EffectsGrid"
                          ItemsSource="{Binding Effects}"
                          Margin="8"
                          IsReadOnly="False">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled, Mode=TwoWay}" Width="75" />
                        <DataGridTextColumn Header="Effect" Binding="{Binding Name}" IsReadOnly="True" Width="170" />
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" IsReadOnly="True" Width="90" />
                        <DataGridTextColumn Header="Minimum level" Binding="{Binding MinimumLevel}" IsReadOnly="True" Width="110" />
                        <DataGridTextColumn Header="Duration" Binding="{Binding DurationSeconds}" IsReadOnly="True" Width="80" />
                        <DataGridTextColumn Header="Weight" Binding="{Binding Weight}" IsReadOnly="True" Width="70" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" IsReadOnly="True" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Detected keybinds">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Bindings are read from Destiny's cvars.xml. The file is never modified."
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,0,0,8" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding DetectedBindings}"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="*" />
                            <DataGridTextColumn Header="Primary" Binding="{Binding PrimaryDisplay}" Width="180" />
                            <DataGridTextColumn Header="Secondary" Binding="{Binding SecondaryDisplay}" Width="180" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Event log">
                <ListBox x:Name="EventLogListBox"
                         Margin="8"
                         Background="#141821"
                         Foreground="White"
                         BorderBrush="#343A49" />
            </TabItem>
        </TabControl>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="StartButton" Grid.Column="0" Content="Start" Click="StartButton_Click" />
            <Button x:Name="StopButton" Grid.Column="1" Content="Stop" Click="StopButton_Click" Background="#A43A4B" />
            <Button x:Name="TriggerNowButton" Grid.Column="2" Content="Trigger now" Click="TriggerNowButton_Click" />
            <Button x:Name="RefreshBindingsButton" Grid.Column="3" Content="Refresh bindings" Click="RefreshBindingsButton_Click" Background="#3F6CB5" />
            <Button x:Name="OpenBindingsFolderButton" Grid.Column="4" Content="Open bindings folder" Click="OpenBindingsFolderButton_Click" Background="#3F6CB5" />

            <TextBlock x:Name="StatusTextBlock"
                       Grid.Column="5"
                       Text="Stopped"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource MutedBrush}" />
        </Grid>
    </Grid>
</Window>
