<Window x:Class="CryoChaos.Views.CaptureDiagnosticWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CryoChaos.Views"
        Title="CryoChaos Capture Diagnostic"
        Width="1000"
        Height="650"
        MinWidth="640"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#11141B">
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition x:Name="DiagnosticsRow" Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="PreviewBorder" Grid.Row="0" Margin="12" BorderBrush="#596174" BorderThickness="1">
            <views:D3D11PreviewHost x:Name="LiveRenderer" />
        </Border>

        <StackPanel x:Name="DiagnosticsPanel" Grid.Row="1" Margin="12,0,12,12">
            <TextBlock x:Name="StatusText"
                       Foreground="White"
                       FontFamily="Consolas"
                       FontSize="14"
                       Text="Starting capture..." />
            <TextBlock x:Name="HelpText"
                       Margin="0,5,0,0"
                       Foreground="#AAB2C3"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
