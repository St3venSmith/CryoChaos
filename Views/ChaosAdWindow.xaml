<Window x:Class="CryoChaos.Views.ChaosAdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CryoChaos Ad Break"
        Width="720"
        Height="410"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="White"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <Border Background="#F20B0E16"
            BorderBrush="#7C5CFC"
            BorderThickness="2"
            CornerRadius="18"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="CRYOCHAOS AD BREAK"
                               Foreground="#AE9CFF"
                               FontSize="13"
                               FontWeight="Bold" />
                    <TextBlock Text="Your movement has been sponsored"
                               FontSize="27"
                               FontWeight="Bold"
                               Margin="0,5,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#272D3D"
                        CornerRadius="14"
                        Padding="12,7"
                        VerticalAlignment="Top">
                    <TextBlock Text="AD" FontWeight="Bold" Foreground="#D8DDEC" />
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Background="#171D2A"
                    BorderBrush="#30384B"
                    BorderThickness="1"
                    CornerRadius="13"
                    Margin="0,22,0,20"
                    Padding="28">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Tired of predictable controls?"
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Try waiting patiently. Movement resumes only after the skip button is ready."
                               Foreground="#AEB7CB"
                               FontSize="15"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="40,12,40,0" />
                    <ProgressBar x:Name="CountdownProgressBar"
                                 Minimum="0"
                                 Maximum="1"
                                 Height="7"
                                 Value="0"
                                 Foreground="#7C5CFC"
                                 Background="#272D3D"
                                 BorderThickness="0"
                                 Margin="20,25,20,0" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CountdownTextBlock"
                           Text="Movement locked for 4.0 seconds"
                           Foreground="#AEB7CB"
                           VerticalAlignment="Center" />
                <Button x:Name="SkipButton"
                        Grid.Column="1"
                        Content="Skip in 4.0"
                        IsEnabled="False"
                        MinWidth="132"
                        Margin="0"
                        Click="SkipButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
